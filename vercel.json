{
  "version": 2,
  "name": "calcphi",
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "redirects": [
    { "source": "/in", "destination": "/india/", "permanent": true },
    { "source": "/us", "destination": "/usa/", "permanent": true },
    { "source": "/ca", "destination": "/canada/", "permanent": true },
    { "source": "/au", "destination": "/australia/", "permanent": true },
    { "source": "/in/:path*", "destination": "/india/:path*", "permanent": true },
    { "source": "/us/:path*", "destination": "/usa/:path*", "permanent": true },
    { "source": "/ca/:path*", "destination": "/canada/:path*", "permanent": true },
    { "source": "/au/:path*", "destination": "/australia/:path*", "permanent": true },
    { "source": "/sip-main.html", "destination": "/india/sip-calculator/", "permanent": true },
    { "source": "/emi-calculator.html", "destination": "/india/emi-calculator/", "permanent": true },
    { "source": "/income-tax.html", "destination": "/india/income-tax-calculator/", "permanent": true },
    { "source": "/ppf-calculator.html", "destination": "/india/ppf-calculator/", "permanent": true },
    { "source": "/nps-calculator.html", "destination": "/india/nps-calculator/", "permanent": true },
    { "source": "/fd-calculator.html", "destination": "/india/fd-calculator/", "permanent": true },
    { "source": "/rd-calculator.html", "destination": "/india/rd-calculator/", "permanent": true },
    { "source": "/lumpsum-calculator.html", "destination": "/india/lumpsum-calculator/", "permanent": true },
    { "source": "/step-up-sip.html", "destination": "/india/step-up-sip-calculator/", "permanent": true },
    { "source": "/fire-calculator.html", "destination": "/india/", "permanent": true },
    { "source": "/gst-calculator.html", "destination": "/india/", "permanent": true },
    { "source": "/gratuity-calculator.html", "destination": "/india/", "permanent": true },
    { "source": "/india/sip-main.html", "destination": "/india/sip-calculator/", "permanent": true },
    { "source": "/india/emi-calculator.html", "destination": "/india/emi-calculator/", "permanent": true },
    { "source": "/india/income-tax.html", "destination": "/india/income-tax-calculator/", "permanent": true },
    { "source": "/india/ppf-calculator.html", "destination": "/india/ppf-calculator/", "permanent": true },
    { "source": "/india/nps-calculator.html", "destination": "/india/nps-calculator/", "permanent": true },
    { "source": "/india/fd-calculator.html", "destination": "/india/fd-calculator/", "permanent": true },
    { "source": "/india/rd-calculator.html", "destination": "/india/rd-calculator/", "permanent": true },
    { "source": "/india/lumpsum-calculator.html", "destination": "/india/lumpsum-calculator/", "permanent": true },
    { "source": "/india/step-up-sip.html", "destination": "/india/step-up-sip-calculator/", "permanent": true },
    { "source": "/india/income-tax-calculator.html", "destination": "/india/income-tax-calculator/", "permanent": true },
    { "source": "/india/hra-calculator.html", "destination": "/india/hra-calculator/", "permanent": true },
    { "source": "/india/about.html", "destination": "/about/", "permanent": true },
    { "source": "/india/contact.html", "destination": "/contact/", "permanent": true },
    { "source": "/india/privacy.html", "destination": "/privacy/", "permanent": true },
    { "source": "/about.html", "destination": "/about/", "permanent": true },
    { "source": "/contact.html", "destination": "/contact/", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
