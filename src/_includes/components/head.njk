<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Source+Serif+4:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

<title>{{ title }}{% if "CalcPhi" not in title %} | CalcPhi{% endif %}</title>
<meta name="description" content="{{ description }}">

<link rel="canonical" href="{{ site.url }}{{ permalink }}">
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="{{ site.url }}{{ permalink }}">
<meta property="og:image" content="{{ site.url }}{{ ogImage if ogImage else site.defaultOgImage }}">
<meta property="og:site_name" content="CalcPhi">

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="{{ site.url }}{{ ogImage if ogImage else site.defaultOgImage }}">

<!-- Hreflang -->
{% if hreflang %}
  {% for h in hreflang %}
  <link rel="alternate" hreflang="{{ h.lang }}" href="{{ site.url }}{{ h.url }}">
  {% endfor %}
{% endif %}

<!-- Language -->
<meta name="language" content="en">

<!-- Critical CSS inlined -->
{% inlineCss "critical.css" %}

<!-- Main stylesheet -->
<link rel="stylesheet" href="/assets/css/main.css?v=2">

<!-- Favicon (inline SVG data URI) -->
<link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">

<!-- Per-page schema is injected by the layout into <body> -->
