---
layout: layouts/base.njk
---
{% set author = authors[authorId] %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ author.name }}",
  "jobTitle": "{{ author.title }}",
  "description": {{ author.shortBio | dump | safe }},
  "url": "{{ site.url }}{{ author.url }}",
  "image": "{{ site.url }}{{ author.image }}",
  "affiliation": {
    "@type": "Organization",
    "name": "CalcPhi",
    "url": "{{ site.url }}"
  },
  "knowsAbout": {{ author.expertise | dump | safe }},
  "sameAs": ["{{ author.linkedin }}"]
}
</script>

<main id="main-content">

  <!-- Author hero -->
  <div class="author-hero">
    <div class="author-hero__inner">
      <img src="{{ author.image }}"
           alt="{{ author.name }}, {{ author.credentials }}"
           class="author-hero__photo"
           width="160" height="160"
           loading="eager">
      <div class="author-hero__text">
        <span class="author-hero__cred">{{ author.credentials }}</span>
        <h1>{{ author.name }}</h1>
        <p class="author-hero__title">{{ author.title }}</p>
        <div class="author-hero__actions">
          <a href="{{ author.linkedin }}" class="author-hero__linkedin" rel="noopener noreferrer nofollow" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Author body -->
  <div class="author-body">

    <div class="author-main">

      <section class="author-section">
        <h2>About {{ author.name }}</h2>
        <p>{{ author.fullBio }}</p>
      </section>

      {% if author.articles and author.articles.length %}
      <section class="author-section">
        <h2>Articles by {{ author.name }}</h2>
        <ul class="author-articles-list">
          {% for article in author.articles %}
          <li>
            <a href="{{ article.url }}">{{ article.title }}</a>
          </li>
          {% endfor %}
        </ul>
      </section>
      {% endif %}

      <section class="author-section author-section--muted">
        <h2>Editorial Independence</h2>
        <p>All content produced by {{ author.name }} for CalcPhi is editorially independent. Calculator results and written content are never influenced by advertising relationships or affiliate commissions. All rates and regulatory figures are sourced directly from CBDT, AMFI, RBI, SEBI, or PFRDA publications. See our <a href="/about/">editorial standards</a> for full details.</p>
      </section>

    </div>

    <aside class="author-sidebar">

      <div class="author-sidebar__card">
        <h3>Areas of Expertise</h3>
        <ul class="author-expertise-list">
          {% for skill in author.expertise %}
          <li>{{ skill }}</li>
          {% endfor %}
        </ul>
      </div>

      <div class="author-sidebar__card author-sidebar__verified">
        <div class="author-verified__icon">✓</div>
        <p><strong>Verified Expert</strong></p>
        <p>Credentials verified by the CalcPhi editorial team. All published content reviewed for accuracy against authoritative sources.</p>
      </div>

      <div class="author-sidebar__card">
        <h3>More Authors</h3>
        <a href="/about/authors/" class="author-sidebar__link">View all CalcPhi authors →</a>
      </div>

    </aside>

  </div>

</main>
