---
layout: layouts/base.njk
---
<main id="main-content">

  <div class="hub-hero">
    <div class="hub-hero__inner">
      <div class="cp-tag">Financial Calculators</div>
      <h1>{{ h1 }}</h1>
      {% if heroSubtitle %}<p>{{ heroSubtitle }}</p>{% endif %}
    </div>
  </div>

  <div class="hub-content">
    {{ content | safe }}

    {% set catSlugs = {
      "Mutual Funds & Investments": "mutual-funds",
      "Tax Calculators": "tax",
      "Loans & Borrowing": "loans",
      "Banking & Fixed Income": "banking",
      "Government Schemes": "government",
      "Retirement Planning": "retirement",
      "Salary & Employment": "salary",
      "Real Estate": "real-estate",
      "Insurance": "insurance"
    } %}

    {% for cat in ["Mutual Funds & Investments", "Tax Calculators", "Loans & Borrowing", "Banking & Fixed Income", "Government Schemes", "Retirement Planning", "Salary & Employment", "Real Estate", "Insurance"] %}
    <div class="hub-category" id="{{ catSlugs[cat] }}">
      <h2>{{ cat }}</h2>
      <div class="hub-grid">
        {% for calc in india.calculators %}
        {% if calc.category == cat %}
        <a href="{{ calc.url }}" class="related-card">
          <h3>{{ calc.title }}</h3>
          <p>{{ calc.shortDescription }}</p>
        </a>
        {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

</main>
