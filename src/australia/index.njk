<script>
(function () {
  // [loanAUD, ratePercent, termYears]
  var scenarios = [
    [650000,  6.24, 30],
    [800000,  6.50, 25],
    [450000,  5.99, 20],
    [1100000, 6.74, 30],
  ];

  function monthly(loan, rate, term) {
    var r = rate / 100 / 12, n = term * 12;
    var pv = Math.pow(1 + r, n);
    return loan * r * pv / (pv - 1);
  }

  function fmt(n) {
    return 'A$' + Math.round(n).toLocaleString('en-AU');
  }

  function set(idx) {
    var s = scenarios[idx];
    var loan = s[0], rate = s[1], term = s[2];
    var mo = monthly(loan, rate, term);
    var total = mo * term * 12;
    var interest = total - loan;

    // Slider %: loan 200k–1.5M, rate 3–12%, term 10–30yr
    document.getElementById('au-hw-loan-fill').style.width  = ((loan - 200000) / 1300000 * 100).toFixed(1) + '%';
    document.getElementById('au-hw-rate-fill').style.width  = ((rate - 3) / 9 * 100).toFixed(1) + '%';
    document.getElementById('au-hw-term-fill').style.width  = ((term - 10) / 20 * 100).toFixed(1) + '%';

    // Fade numbers during update
    var monthly_el = document.getElementById('au-hw-monthly');
    monthly_el.style.opacity = '0';
    setTimeout(function () {
      document.getElementById('au-hw-loan').textContent      = fmt(loan);
      document.getElementById('au-hw-rate').textContent      = rate.toFixed(2) + '% p.a.';
      document.getElementById('au-hw-term').textContent      = term + ' years';
      monthly_el.textContent                                 = fmt(mo);
      document.getElementById('au-hw-principal').textContent = fmt(loan);
      document.getElementById('au-hw-interest').textContent  = fmt(interest);
      document.getElementById('au-hw-total').textContent     = fmt(total);
      monthly_el.style.opacity = '1';
    }, 280);
  }

  var cur = 0;
  set(0);
  setInterval(function () {
    cur = (cur + 1) % scenarios.length;
    set(cur);
  }, 3500);
})();
</script>
