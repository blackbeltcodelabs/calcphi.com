          <thead>
            <tr>
              <th>Taxable Income</th>
              <th>Marginal Rate</th>
              <th>Tax on This Portion</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>$0 – $18,200</td>
              <td>0%</td>
              <td>Nil</td>
            </tr>
            <tr>
              <td>$18,201 – $45,000</td>
              <td>19%</td>
              <td>19c per $1 over $18,200</td>
            </tr>
            <tr>
