        <script>
        (function () {
          var slides = [document.getElementById('hp-slide-0'), document.getElementById('hp-slide-1')];
          var dots   = [document.getElementById('hp-dot-0'),  document.getElementById('hp-dot-1')];
          var cur = 0;

          function goTo(idx) {
            slides[cur].classList.remove('active');
            dots[cur].classList.remove('dot-active');
            dots[cur].setAttribute('aria-selected','false');
            cur = idx;
            slides[cur].classList.add('active');
            dots[cur].classList.add('dot-active');
            dots[cur].setAttribute('aria-selected','true');
          }

          // Dots are clickable
          dots.forEach(function(d, i) { d.addEventListener('click', function(){ goTo(i); }); });

          // Auto-advance every 5 s
          var timer = setInterval(function () { goTo((cur + 1) % slides.length); }, 5000);

          // Pause on hover
          var carousel = document.getElementById('hp-carousel');
          carousel.addEventListener('mouseenter', function () { clearInterval(timer); });
          carousel.addEventListener('mouseleave', function () {
            timer = setInterval(function () { goTo((cur + 1) % slides.length); }, 5000);
          });

          // ── Mortgage widget animation ──────────────────────
          var scenarios = [
            [650000, 6.24, 30],
            [800000, 6.50, 25],
            [450000, 5.99, 20],
            [1100000, 6.74, 30],
          ];
          var mCur = 0;

          function calcMo(loan, rate, term) {
            var r = rate / 100 / 12, n = term * 12;
            var pv = Math.pow(1 + r, n);
            return loan * r * pv / (pv - 1);
          }
          function fmt(n) { return 'A$' + Math.round(n).toLocaleString('en-AU'); }

          function setMortgage(idx) {
            var s = scenarios[idx], loan = s[0], rate = s[1], term = s[2];
            var mo = calcMo(loan, rate, term), total = mo * term * 12, interest = total - loan;

            document.getElementById('hp-au-loan-fill').style.width = ((loan-200000)/1300000*100).toFixed(1)+'%';
            document.getElementById('hp-au-rate-fill').style.width = ((rate-3)/9*100).toFixed(1)+'%';
            document.getElementById('hp-au-term-fill').style.width = ((term-10)/20*100).toFixed(1)+'%';

            var el = document.getElementById('hp-au-monthly');
            el.style.opacity = '0';
            setTimeout(function () {
              document.getElementById('hp-au-loan').textContent      = fmt(loan);
              document.getElementById('hp-au-rate').textContent      = rate.toFixed(2)+'% p.a.';
              document.getElementById('hp-au-term').textContent      = term+' years';
              el.textContent                                         = fmt(mo);
              document.getElementById('hp-au-principal').textContent = fmt(loan);
              document.getElementById('hp-au-interest').textContent  = fmt(interest);
              document.getElementById('hp-au-total').textContent     = fmt(total);
              el.style.opacity = '1';
            }, 280);
          }

          setMortgage(0);
          setInterval(function () { mCur = (mCur+1) % scenarios.length; setMortgage(mCur); }, 3500);
        })();
        </script>
      </div>
    </div>
  </section>

