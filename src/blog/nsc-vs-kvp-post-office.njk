      <tbody>
        <tr><td>Current rate</td><td>7.7%</td><td>7.5%</td><td>7.5%</td></tr>
        <tr><td>Compounding</td><td>Annual (paid at maturity)</td><td>Annual (paid at maturity)</td><td>Annual (interest paid annually)</td></tr>
        <tr><td>Tenure</td><td>5 years (fixed)</td><td>~9 years 7 months</td><td>1, 2, 3, 5 years</td></tr>
        <tr><td>80C eligible</td><td>Yes (investment)</td><td>No</td><td>Yes (5-year only)</td></tr>
        <tr><td>Tax on interest</td><td>Taxable (accrual), but 80C on accrued interest</td><td>Fully taxable at maturity</td><td>Taxable annually</td></tr>
