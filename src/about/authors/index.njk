<main id="main-content">

  <div class="authors-page-header">
    <div class="authors-page-header__inner">
      <p class="authors-page-header__eyebrow">Editorial Teams</p>
      <h1>Meet Our Financial Experts</h1>
      <p class="authors-page-header__sub">CalcPhi maintains separate editorial teams for each market. Every calculator and article is written and independently verified by a qualified financial professional with direct knowledge of local regulations.</p>
    </div>
  </div>

  <div class="authors-list-wrap">
    <div style="max-width:860px;margin:0 auto;padding:0 1.5rem 3rem;">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:2rem;">

        <a href="/india/authors/" class="cp-card" style="display:block;padding:2rem;text-decoration:none;color:inherit;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">🇮🇳</div>
          <h2 style="margin:0 0 .5rem;font-size:1.25rem;">India Editorial Team</h2>
          <p style="color:var(--color-text-secondary);margin:0 0 1rem;font-size:.95rem;">CFA, CA (ICAI), and CFP specialists in Indian capital markets, SEBI, CBDT, and RBI regulations.</p>
          <div style="display:flex;flex-direction:column;gap:.5rem;margin-bottom:1.5rem;">
            {% for key, author in authors %}
            {% if author.market == "india" %}
            <span style="font-size:.9rem;color:var(--color-text);">{{ author.name }} · {{ author.credentials }}</span>
            {% endif %}
            {% endfor %}
          </div>
          <span style="color:var(--color-accent);font-weight:600;font-size:.9rem;">View India Authors →</span>
        </a>

        <a href="/australia/authors/" class="cp-card" style="display:block;padding:2rem;text-decoration:none;color:inherit;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">🇦🇺</div>
          <h2 style="margin:0 0 .5rem;font-size:1.25rem;">Australia Editorial Team</h2>
          <p style="color:var(--color-text-secondary);margin:0 0 1rem;font-size:.95rem;">CFA, CPA Australia, and CFP (FPA) specialists in ATO, APRA, ASIC, and Services Australia regulations.</p>
          <div style="display:flex;flex-direction:column;gap:.5rem;margin-bottom:1.5rem;">
            {% for key, author in authors %}
            {% if author.market == "australia" %}
            <span style="font-size:.9rem;color:var(--color-text);">{{ author.name }} · {{ author.credentials }}</span>
            {% endif %}
            {% endfor %}
          </div>
          <span style="color:var(--color-accent);font-weight:600;font-size:.9rem;">View Australia Authors →</span>
        </a>

      </div>

    </div>
  </div>

</main>
